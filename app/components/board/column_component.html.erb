<div class="flex-shrink-0 w-80 bg-white rounded-xl shadow-sm border border-gray-200 flex flex-col max-h-full">
  <div class="px-4 py-3 border-b border-gray-100">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-2">
        <span class="w-3 h-3 rounded-full" style="background-color: <%= @board_column.color %>"></span>
        <h2 class="font-semibold text-gray-800 text-sm"><%= @board_column.name %></h2>
      </div>
      <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-gray-100 text-xs font-medium text-gray-600">
        <%= @board_column.cards.size %>
      </span>
    </div>
  </div>

  <div class="flex-1 overflow-y-auto p-3 space-y-3"
       id="column_<%= @board_column.id %>_cards"
       data-controller="sortable"
       data-sortable-board-id-value="<%= @board.id %>"
       data-column-id="<%= @board_column.id %>">
    <% @board_column.cards.each do |card| %>
      <%= render Card::CardComponent.new(card: card, board: @board) %>
    <% end %>
  </div>

  <div class="p-3 border-t border-gray-100">
    <%= render Card::NewFormComponent.new(column: @board_column, board: @board) %>
  </div>
</div>
