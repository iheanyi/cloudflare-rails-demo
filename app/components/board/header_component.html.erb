<header class="bg-gray-900 text-white px-6 py-3 flex items-center justify-between shadow-lg">
  <div class="flex items-center gap-4">
    <h1 class="text-xl font-bold tracking-tight" style="text-wrap: balance;"><%= @board.name %></h1>
    <div class="flex items-center gap-2 text-sm text-gray-400"
         data-controller="presence"
         data-presence-board-id-value="<%= @board.id %>">
      <span class="inline-block w-2 h-2 rounded-full bg-green-400 animate-pulse" aria-hidden="true"></span>
      <span data-presence-target="count">1 viewing</span>
    </div>
  </div>
  <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-orange-500/20 text-orange-300 border border-orange-500/30">
    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>
    Rails 8 + Cloudflare Containers
  </span>
</header>
