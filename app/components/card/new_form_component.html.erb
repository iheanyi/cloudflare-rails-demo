<div data-controller="new-card">
  <button type="button"
          data-new-card-target="button"
          data-action="click->new-card#toggle"
          class="w-full py-2 text-sm text-gray-500 hover:text-gray-700 hover:bg-gray-50 rounded-lg transition-colors flex items-center justify-center gap-1 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
    </svg>
    Add Card
  </button>

  <div data-new-card-target="form" class="hidden">
    <%= form_with url: board_cards_path(@board),
          method: :post,
          class: "space-y-2",
          data: { action: "turbo:submit-end->new-card#submitEnd" } do |f| %>
      <%= f.hidden_field :card, value: nil, name: nil %>
      <input type="hidden" name="card[board_column_id]" value="<%= @column.id %>">
      <label for="new_card_title_<%= @column.id %>" class="sr-only">Card title</label>
      <input type="text"
             id="new_card_title_<%= @column.id %>"
             name="card[title]"
             data-new-card-target="input"
             placeholder="Enter a title\u2026"
             required
             autocomplete="off"
             class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
      <div class="flex items-center gap-2">
        <button type="submit"
                class="px-3 py-1.5 text-sm font-medium text-white bg-blue-600 rounded-md hover:bg-blue-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 transition-colors">
          Add
        </button>
        <button type="button"
                data-action="click->new-card#toggle"
                class="px-3 py-1.5 text-sm font-medium text-gray-600 hover:text-gray-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 rounded-md transition-colors">
          Cancel
        </button>
      </div>
    <% end %>
  </div>
</div>
